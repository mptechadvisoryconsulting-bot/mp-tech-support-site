:root {
  --bg: #f6f8fb;
  --ink: #172033;
  --muted: #5e6b7e;
  --card: #ffffff;
  --accent: #2f4fa3;
  --accent-dark: #1d3470;
  --border: #dfe6f0;
  --soft: #edf2ff;
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  font-family: Arial, Helvetica, sans-serif;
  background: var(--bg);
  color: var(--ink);
}

a { color: inherit; }

.hero {
  background:
    radial-gradient(circle at top right, rgba(47, 79, 163, 0.22), transparent 32rem),
    linear-gradient(135deg, #ffffff 0%, #edf2ff 100%);
  padding: 28px;
}

.nav {
  max-width: 1180px;
  margin: 0 auto 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 14px;
}

.logo {
  width: 54px;
  height: 54px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  background: var(--accent);
  color: white;
  font-weight: 800;
  letter-spacing: -0.04em;
}

.eyebrow {
  margin: 0 0 4px;
  color: var(--accent);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: 12px;
}

h1, h2, h3, p { margin-top: 0; }

h1 {
  margin-bottom: 0;
  font-size: 22px;
}

.heroGrid {
  max-width: 1180px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.6fr);
  gap: 28px;
  align-items: stretch;
}

.heroCopy {
  padding: 42px;
  background: rgba(255,255,255,0.75);
  border: 1px solid rgba(255,255,255,0.85);
  border-radius: 28px;
  box-shadow: 0 20px 60px rgba(23,32,51,0.08);
}

.badge {
  display: inline-flex;
  padding: 8px 12px;
  border-radius: 999px;
  background: var(--soft);
  color: var(--accent-dark);
  font-weight: 700;
  font-size: 13px;
}

.heroCopy h2 {
  font-size: clamp(38px, 6vw, 68px);
  line-height: 0.96;
  letter-spacing: -0.06em;
  margin-bottom: 20px;
}

.heroCopy p {
  max-width: 760px;
  color: var(--muted);
  font-size: 18px;
  line-height: 1.7;
}

.actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 28px;
}

.primary, .secondary, .navButton {
  text-decoration: none;
  border-radius: 999px;
  padding: 13px 18px;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.primary {
  background: var(--accent);
  color: white;
}

.secondary, .navButton {
  background: white;
  color: var(--accent-dark);
  border: 1px solid var(--border);
}

.secondary.dark {
  background: var(--ink);
  color: white;
  border-color: var(--ink);
}

.infoCard, .detailCard {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 28px;
  box-shadow: 0 14px 40px rgba(23,32,51,0.06);
}

.infoCard {
  padding: 30px;
}

.infoCard h3, .detailCard h3 {
  font-size: 22px;
}

.infoCard ul {
  padding-left: 20px;
  color: var(--muted);
  line-height: 1.9;
}

.details {
  max-width: 1180px;
  margin: 36px auto;
  padding: 0 28px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.detailCard {
  padding: 26px;
}

.detailCard p {
  color: var(--muted);
  line-height: 1.6;
  margin-bottom: 0;
}

.formSection {
  max-width: 1180px;
  margin: 0 auto 48px;
  padding: 28px;
}

.sectionHeader {
  text-align: center;
  max-width: 760px;
  margin: 0 auto 26px;
}

.sectionHeader h2 {
  font-size: clamp(30px, 4vw, 48px);
  letter-spacing: -0.04em;
  margin-bottom: 12px;
}

.sectionHeader p {
  color: var(--muted);
  line-height: 1.7;
}

.iframeWrap {
  background: white;
  border: 1px solid var(--border);
  border-radius: 28px;
  overflow: hidden;
  box-shadow: 0 20px 70px rgba(23,32,51,0.08);
}

iframe {
  width: 100%;
  min-height: 1050px;
  border: 0;
  display: block;
}

footer {
  text-align: center;
  color: var(--muted);
  padding: 24px;
  border-top: 1px solid var(--border);
}

@media (max-width: 850px) {
  .nav, .heroGrid, .details {
    grid-template-columns: 1fr;
  }

  .nav {
    align-items: flex-start;
    flex-direction: column;
    margin-bottom: 28px;
  }

  .heroCopy {
    padding: 28px;
  }

  .details {
    margin-top: 18px;
  }

  iframe {
    min-height: 1150px;
  }
}
